# AgentPiro - Configuración Personal
# Copia este archivo como .env y completa tus credenciales

# Ollama - Modelo Local (por defecto)
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# Ollama - Modelo Fallback (alternativo en mismo host)
OLLAMA_FALLBACK_MODEL="gemma4:31b-cloud"

# Ollama Cloud - API Remota (prioridad principal)
OLLAMA_CLOUD_ENABLED="false"
OLLAMA_CLOUD_URL="https://api.ollama.com"
OLLAMA_CLOUD_MODEL="gemma3:12b"
OLLAMA_CLOUD_API_KEY="tu-api-key-aqui"

# Memoria Persistente
DB_PATH="./memory.db"

# Configuración del Agente
MAX_ITERATIONS=5
AGENT_NAME="AgentPiro"
DEBUG_MODE=false

# Seguridad - Lista blanca de comandos permitidos (separados por coma)
ALLOWED_COMMANDS="date,time,cal,echo,ls,pwd,whoami,uname,cat"

# Texto a Voz (TTS)
TTS_ENABLED="true"
TTS_PROVIDER="edge"
TTS_VOICE="es-VE-PaolaNeural"
TTS_RATE="+30%"
TTS_PITCH="-15Hz"
TTS_AUTO_PLAY="true"
